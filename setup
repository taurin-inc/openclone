#!/usr/bin/env bash
# openclone setup — register this checkout as an enabled Claude Code plugin.
#
# Expected to be run from the install location:
#   ~/.claude/plugins/marketplaces/openclone
#
# Registers `openclone@openclone` in ~/.claude/settings.json under `enabledPlugins`,
# preserving any other keys/values in that file. Idempotent.

set -eu

expected_dir="$HOME/.claude/plugins/marketplaces/openclone"
here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ "$here" != "$expected_dir" ]; then
  printf '오류: setup은 %s 에서 실행해야 합니다\n' "$expected_dir" >&2
  printf '     현재 위치: %s\n' "$here" >&2
  printf '\nREADME의 설치 명령어를 다시 실행해 올바른 경로로 clone 해주세요.\n' >&2
  exit 1
fi

# Self-heal on re-run. Only active when this is a git checkout (normal install).
# Dev-link users who intentionally symlink plugin files should keep their links
# intact: we only clean broken or out-of-repo symlinks.
if [ -d "$here/.git" ]; then
  cd "$here"

  # 1) marketplace.json: clean broken / foreign symlinks, restore shipped file.
  mp="$here/.claude-plugin/marketplace.json"
  if [ -L "$mp" ]; then
    raw_target=$(readlink "$mp" 2>/dev/null || true)
    # Resolve both the symlink and the install root to their physical paths so
    # macOS /private-prefix canonicalization doesn't make internal targets look
    # external.
    here_real=$(cd "$here" && pwd -P 2>/dev/null || printf '%s' "$here")
    if command -v python3 >/dev/null 2>&1; then
      resolved=$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$mp" 2>/dev/null || true)
    else
      resolved=$(readlink -f "$mp" 2>/dev/null || true)
    fi
    heal=0
    if [ -z "$resolved" ] || [ ! -e "$resolved" ]; then
      heal=1
    elif [ "${resolved#"$here_real"/}" = "$resolved" ]; then
      # target is outside this repo — treat as stale dev-link leftover
      heal=1
    fi
    if [ "$heal" = "1" ]; then
      printf 'self-heal: marketplace.json이 외부/깨진 symlink입니다 (→ %s). shipped 파일로 복원합니다.\n' "$raw_target"
      rm -f "$mp"
      git checkout -- .claude-plugin/marketplace.json >/dev/null 2>&1 || true
    fi
  fi

  # 2) sparse-checkout: migrate cone layout to non-cone (lazy-fetch knowledge).
  is_cone=$(git config --local --get core.sparseCheckoutCone 2>/dev/null || echo "")
  if [ "$is_cone" = "true" ] && [ -f ".git/info/sparse-checkout" ]; then
    printf 'self-heal: sparse-checkout을 non-cone 레이아웃으로 전환합니다.\n'
    git sparse-checkout set --no-cone '/*' '!/clones/*/knowledge/' >/dev/null 2>&1 || true
  fi

  # 3) non-fast-forward warning: when origin/main was rewritten, this install
  #    can no longer auto-update. Do NOT reset — just tell the user to reinstall.
  if GIT_TERMINAL_PROMPT=0 git fetch origin "+refs/heads/main:refs/remotes/origin/main" --quiet 2>/dev/null; then
    if ! git merge-base --is-ancestor HEAD origin/main 2>/dev/null; then
      printf '\n경고: 원격 main이 rewrite되어 자동 업데이트가 따라갈 수 없습니다.\n' >&2
      printf '      복구: rm -rf %s\n' "$expected_dir" >&2
      printf '            rm -f ~/.openclone/no-auto-update\n' >&2
      printf '      그 후 README의 설치 one-liner를 재실행해 주세요.\n\n' >&2
    fi
  fi
fi

settings_file="$HOME/.claude/settings.json"
mkdir -p "$HOME/.claude"

if ! command -v python3 >/dev/null 2>&1; then
  printf '오류: setup에는 python3가 필요합니다 (settings.json 안전 편집용)\n' >&2
  exit 1
fi

# Capture stdout into a single marker line so bash can branch the closing
# message on whether this is a fresh activation. Anything user-facing
# (e.g. statusline notice) goes to stderr so it streams through unchanged.
was_enabled_marker=$(python3 - "$settings_file" <<'PY'
import json, os, sys

path = sys.argv[1]
data = {}
if os.path.exists(path):
    try:
        with open(path, "r") as f:
            data = json.load(f)
        if not isinstance(data, dict):
            data = {}
    except Exception:
        data = {}

enabled = data.get("enabledPlugins")
if not isinstance(enabled, dict):
    enabled = {}

enabled_before = enabled.get("openclone@openclone") is True

enabled["openclone@openclone"] = True
data["enabledPlugins"] = enabled

marketplaces = data.get("extraKnownMarketplaces")
if not isinstance(marketplaces, dict):
    marketplaces = {}

marketplaces["openclone"] = {
    "source": {
        "source": "directory",
        "path": os.path.expanduser("~/.claude/plugins/marketplaces/openclone"),
    }
}
data["extraKnownMarketplaces"] = marketplaces

# Statusline — only inject if the user has no statusLine yet, or if we were
# already the one who set it (detected by our managed marker). Never overwrite
# a third-party/user statusline silently.
OWN_STATUSLINE = {
    "type": "command",
    "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/statusline.sh",
    "_openclone_managed": True,
}
existing = data.get("statusLine")
if existing is None or (isinstance(existing, dict) and existing.get("_openclone_managed") is True):
    data["statusLine"] = OWN_STATUSLINE
elif isinstance(existing, dict):
    print(
        "참고: 이미 다른 statusLine이 설정되어 있어 openclone statusline은 주입하지 않았습니다.\n"
        "      활성 클론/대화방 상태를 상태줄에 보고 싶다면 settings.json의 statusLine을\n"
        '      {"type":"command","command":"bash ${CLAUDE_PLUGIN_ROOT}/scripts/statusline.sh"} 로 교체하세요.',
        file=sys.stderr,
    )

with open(path, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")

print(f"OPENCLONE_WAS_ENABLED={1 if enabled_before else 0}")
PY
)
was_enabled="${was_enabled_marker##*=}"

mkdir -p "$HOME/.openclone"

printf 'openclone 설치 완료.\n\n'

if [ "$was_enabled" = "0" ]; then
  cat <<'MSG_RESTART'
==============================================================
  다음 단계: Claude Code를 완전히 종료한 뒤 다시 실행하세요.
==============================================================

  주의: /reload-plugins 만으로는 처음 활성화된 플러그인이 잡히지 않습니다.
        (재시작하지 않으면 `/openclone` 입력 시 "Unknown command"가 뜹니다.)

  재시작 후 첫 메시지로 /openclone 을 쳐서 홈 패널이 뜨는지 확인하세요.

MSG_RESTART
else
  cat <<'MSG_RELOAD'
다음 단계:
  • 실행 중인 Claude Code 세션에서 /reload-plugins 실행
    (이미 활성화돼 있던 플러그인이라 핫리로드로 충분합니다)
  • hooks/hooks.json 을 수정한 적이 있다면 한 번 재시작이 필요합니다

확인: /openclone 으로 홈 패널이 뜨면 OK.

MSG_RELOAD
fi

cat <<'MSG_COMMON'
사용해 보세요:
  /openclone                    — 홈 패널 (카테고리별 클론 목록, 번호/이름으로 선택)
  /openclone <name | N>         — 해당 클론 활성화 (built-in은 최초 사용 시 지식 lazy-fetch)
  /openclone room <A> <B> ...   — 단체 대화방 열기 (가장 적절한 클론이 자동 응답)
  /openclone panel vc "..."     — 카테고리 패널 (vc, dev, founder, pm, designer, writer, marketing, hr)
  /openclone stop               — 활성 클론과 방 모두 종료

상태줄: 활성 클론 또는 방이 열려 있을 때 Claude Code 상태줄에 `openclone · <이름>` 또는 `openclone · room: a, b, c` 가 표시됩니다.
  (이미 settings.json에 본인 statusLine이 있으면 덮어쓰지 않고 건너뜁니다.)

자동 업데이트: 켜짐. 세션 시작 시 1시간당 1회 백그라운드 실행.
  끄기: touch ~/.openclone/no-auto-update
  다시 켜기: rm ~/.openclone/no-auto-update

제거: 이 디렉터리에서 ./uninstall 실행.
MSG_COMMON
