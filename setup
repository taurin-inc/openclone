#!/usr/bin/env bash
# openclone setup — register this checkout as a standalone Claude Code skill.
#
# Expected to be run from the install location:
#   ~/.claude/skills/openclone
#
# Claude Code auto-discovers skills under ~/.claude/skills/<name>/SKILL.md,
# so no enabledPlugins / marketplace entry is needed. This script only
# registers hooks + statusline in ~/.claude/settings.json, preserving any
# other keys/values. Idempotent.

set -eu

# Honor Claude Code's CLAUDE_CONFIG_DIR override (falls back to ~/.claude).
# All subsequent paths are computed from this so users who relocate their
# config dir are not locked out of install/uninstall.
claude_config_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
expected_dir="$claude_config_dir/skills/openclone"
here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# v1 plugin install detection — hard stop so the old install is cleaned first.
legacy_dir="$claude_config_dir/plugins/marketplaces/openclone"
if [ -d "$legacy_dir" ]; then
  printf '오류: 이전 플러그인 버전이 감지되었습니다: %s\n' "$legacy_dir" >&2
  printf '      먼저 다음을 실행해 주세요:\n' >&2
  printf '        cd %s && ./uninstall\n' "$legacy_dir" >&2
  printf '        rm -f ~/.openclone/no-auto-update\n' >&2
  printf '      그 후 README의 설치 one-liner를 재실행해 주세요.\n' >&2
  exit 1
fi

if [ "$here" != "$expected_dir" ]; then
  printf '오류: setup은 %s 에서 실행해야 합니다\n' "$expected_dir" >&2
  printf '     현재 위치: %s\n' "$here" >&2
  printf '\nREADME의 설치 명령어를 다시 실행해 올바른 경로로 clone 해주세요.\n' >&2
  exit 1
fi

# Self-heal on re-run. Only active when this is a git checkout (normal install).
if [ -d "$here/.git" ]; then
  cd "$here"

  # 1) sparse-checkout: migrate cone layout to non-cone (lazy-fetch knowledge).
  is_cone=$(git config --local --get core.sparseCheckoutCone 2>/dev/null || echo "")
  if [ "$is_cone" = "true" ] && [ -f ".git/info/sparse-checkout" ]; then
    printf 'self-heal: sparse-checkout을 non-cone 레이아웃으로 전환합니다.\n'
    git sparse-checkout set --no-cone '/*' '!/clones/*/knowledge/' >/dev/null 2>&1 || true
  fi

  # 2) non-fast-forward warning: when origin/main was rewritten, this install
  #    can no longer auto-update. Do NOT reset — just tell the user to reinstall.
  if GIT_TERMINAL_PROMPT=0 git fetch origin "+refs/heads/main:refs/remotes/origin/main" --quiet 2>/dev/null; then
    if ! git merge-base --is-ancestor HEAD origin/main 2>/dev/null; then
      printf '\n경고: 원격 main이 rewrite되어 자동 업데이트가 따라갈 수 없습니다.\n' >&2
      printf '      복구: rm -rf %s\n' "$expected_dir" >&2
      printf '            rm -f ~/.openclone/no-auto-update\n' >&2
      printf '      그 후 README의 설치 one-liner를 재실행해 주세요.\n\n' >&2
    fi
  fi
fi

settings_file="$claude_config_dir/settings.json"
mkdir -p "$claude_config_dir"

if ! command -v python3 >/dev/null 2>&1; then
  printf '오류: setup에는 python3가 필요합니다 (settings.json 안전 편집용)\n' >&2
  exit 1
fi

python3 - "$settings_file" "$expected_dir" <<'PY'
import json, os, sys

path = sys.argv[1]
install_dir = sys.argv[2]

data = {}
if os.path.exists(path):
    try:
        with open(path, "r") as f:
            data = json.load(f)
        if not isinstance(data, dict):
            data = {}
    except Exception:
        data = {}

# --- Hooks: UserPromptSubmit (persona injection) + SessionStart (auto-update).
# Register only our managed entries; preserve any existing user hooks.
MANAGED = "_openclone_managed"

def upsert_hook(event_name, command, timeout):
    hooks = data.get("hooks")
    if not isinstance(hooks, dict):
        hooks = {}
        data["hooks"] = hooks
    entries = hooks.get(event_name)
    if not isinstance(entries, list):
        entries = []
        hooks[event_name] = entries

    # Claude Code hooks format:
    #   { "matcher": "...", "hooks": [ { "type": "command", "command": "...", ... } ] }
    # We stash our managed marker on the inner command dict. Find or create
    # a matcher-less group owned by us.
    managed_group = None
    for group in entries:
        if not isinstance(group, dict):
            continue
        inner = group.get("hooks")
        if not isinstance(inner, list):
            continue
        for h in inner:
            if isinstance(h, dict) and h.get(MANAGED) is True and h.get("command", "").startswith(install_dir):
                managed_group = group
                break
        if managed_group is not None:
            break

    new_hook = {
        "type": "command",
        "command": command,
        "timeout": timeout,
        MANAGED: True,
    }

    if managed_group is None:
        entries.append({"hooks": [new_hook]})
    else:
        inner = managed_group.get("hooks")
        # Replace any stale managed entries with the fresh definition.
        inner[:] = [h for h in inner if not (isinstance(h, dict) and h.get(MANAGED) is True and h.get("command", "").startswith(install_dir))]
        inner.append(new_hook)

upsert_hook(
    "UserPromptSubmit",
    os.path.join(install_dir, "hooks/inject-active-clone.sh"),
    5,
)
upsert_hook(
    "SessionStart",
    os.path.join(install_dir, "scripts/session-update.sh"),
    3,
)

# Statusline — only inject if the user has no statusLine yet, or if we were
# already the one who set it (detected by our managed marker). Never overwrite
# a third-party/user statusline silently.
OWN_STATUSLINE = {
    "type": "command",
    "command": "bash " + os.path.join(install_dir, "scripts/statusline.sh"),
    MANAGED: True,
}
existing = data.get("statusLine")
if existing is None or (isinstance(existing, dict) and existing.get(MANAGED) is True):
    data["statusLine"] = OWN_STATUSLINE
elif isinstance(existing, dict):
    statusline_cmd = "bash " + os.path.join(install_dir, "scripts/statusline.sh")
    print(
        "참고: 이미 다른 statusLine이 설정되어 있어 openclone statusline은 주입하지 않았습니다.\n"
        "      활성 클론/대화방 상태를 상태줄에 보고 싶다면 settings.json의 statusLine을\n"
        '      {"type":"command","command":"' + statusline_cmd + '"} 로 교체하세요.'
    )

with open(path, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PY

mkdir -p "$HOME/.openclone"

cat <<MSG
openclone 설치 완료.

활성화 방법:
  • Claude Code는 ${expected_dir}/SKILL.md 을 자동 인식합니다.
  • 새 세션부터 /openclone 이 바로 사용 가능합니다.
  • 실행 중인 세션이 있으면 한 번 재시작하세요 (훅/statusline 적용을 위해).

사용해 보세요:
  /openclone                    — 홈 패널 (카테고리별 클론 목록, 번호/이름으로 선택)
  /openclone <name | N>         — 해당 클론 활성화 (built-in은 최초 사용 시 지식 lazy-fetch)
  /openclone room <A> <B> ...   — 단체 대화방 열기 (가장 적절한 클론이 자동 응답)
  /openclone panel vc "..."     — 카테고리 패널 (vc, tech, founder, expert, influencer, politician, celebrity)
  /openclone stop               — 활성 클론과 방 모두 종료

상태줄: 활성 클론 또는 방이 열려 있을 때 Claude Code 상태줄에 \`openclone · <이름>\` 또는 \`openclone · room: a, b, c\` 가 표시됩니다.
  (이미 settings.json에 본인 statusLine이 있으면 덮어쓰지 않고 건너뜁니다.)

자동 업데이트: 켜짐. 세션 시작 시 1시간당 1회 백그라운드 실행.
  끄기: touch ~/.openclone/no-auto-update
  다시 켜기: rm ~/.openclone/no-auto-update

제거: 이 디렉터리에서 ./uninstall 실행.
MSG
